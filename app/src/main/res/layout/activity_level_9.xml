<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="#F5F5F5">

    <!-- Pause Button -->
    <Button
        android:id="@+id/btnPause"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Pause"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        tools:ignore="HardcodedText" />

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Level 9"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="16dp"
        android:layout_below="@id/btnPause"
        tools:ignore="HardcodedText" />

    <!-- Timer -->
    <TextView
        android:id="@+id/tvTimer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Time: 45s"
        android:textSize="18sp"
        android:textColor="#FF5722"
        android:layout_below="@id/btnPause"
        android:layout_alignParentStart="true"
        android:layout_marginTop="16dp"
        tools:ignore="HardcodedText" />

    <!-- Score Display -->
    <TextView
        android:id="@+id/tvScore"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Score: 0"
        android:textSize="18sp"
        android:textColor="#4CAF50"
        android:layout_below="@id/btnPause"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="16dp"
        tools:ignore="HardcodedText" />

    <!-- Instruction -->
    <TextView
        android:id="@+id/tvInstruction"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Task 1: Waiting to start"
        android:textSize="16sp"
        android:textStyle="bold"
        android:gravity="center"
        android:padding="12dp"
        android:background="#E3F2FD"
        android:layout_below="@id/tvTimer"
        android:layout_marginTop="16dp"
        tools:ignore="HardcodedText" />

    <!-- Progress Display -->
    <TextView
        android:id="@+id/tvProgress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Task: 0/3"
        android:textSize="14sp"
        android:layout_below="@id/tvInstruction"
        android:layout_marginTop="8dp"
        android:layout_centerHorizontal="true"
        tools:ignore="HardcodedText" />

    <!-- Game Area -->
    <FrameLayout
        android:id="@+id/gameArea"
        android:layout_width="match_parent"
        android:layout_height="350dp"
        android:layout_below="@id/tvProgress"
        android:layout_marginTop="16dp"
        android:background="#FFFFFF">

        <!-- Hint Text -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Waiting for task..."
            android:textSize="16sp"
            android:textColor="#999999"
            android:layout_gravity="center"
            tools:ignore="HardcodedText" />

        <!-- Target Button -->
        <Button
            android:id="@+id/targetButton"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:text="Click Me"
            android:textSize="18sp"
            android:visibility="gone"
            android:layout_gravity="center"
            tools:ignore="HardcodedText" />

    </FrameLayout>

    <!-- Sequence Buttons Area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/gameArea"
        android:layout_marginTop="16dp"
        android:orientation="horizontal"
        android:gravity="center">

        <Button
            android:id="@+id/btnSeq1"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:text="1"
            android:textSize="22sp"
            android:textStyle="bold"
            android:visibility="gone"
            android:layout_margin="4dp"
            tools:ignore="ButtonStyle,HardcodedText" />

        <Button
            android:id="@+id/btnSeq2"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:text="2"
            android:textSize="22sp"
            android:textStyle="bold"
            android:visibility="gone"
            android:layout_margin="4dp"
            tools:ignore="ButtonStyle,HardcodedText" />

        <Button
            android:id="@+id/btnSeq3"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:text="3"
            android:textSize="22sp"
            android:textStyle="bold"
            android:visibility="gone"
            android:layout_margin="4dp"
            tools:ignore="ButtonStyle,HardcodedText" />

    </LinearLayout>

    <!-- Test Buttons Area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <Button
            android:id="@+id/btnFinishLevel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Complete (Test)"
            android:textSize="14sp"
            android:layout_marginEnd="8dp"
            tools:ignore="ButtonStyle,HardcodedText" />

        <Button
            android:id="@+id/btnUnfinishLevel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Unfinish (Test)"
            android:textSize="14sp"
            android:layout_marginStart="8dp"
            tools:ignore="ButtonStyle,HardcodedText" />

    </LinearLayout>

</RelativeLayout>